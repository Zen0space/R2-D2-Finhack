{
  "name": "DuitLater",
  "short_name": "DuitLater",
  "description": "BM-first shared PayLater frontend for auth, allowance visibility, and member onboarding.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#f8f4ec",
  "theme_color": "#c8941f",
