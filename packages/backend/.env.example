# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://kutu:kutu_dev@localhost:5432/kutu_digitizer

# Auth
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:4000
# Production only: set to ".duitlater.com" so the session cookie is shared
# across dev.duitlater.com (frontend) and api.dev.duitlater.com (backend).
# Leave blank in local dev — Better Auth defaults work fine on localhost.
AUTH_COOKIE_DOMAIN=

# AWS S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=kutu-uploads

# Anthropic
ANTHROPIC_API_KEY=

# TNG eWallet
TNG_API_BASE=https://sandbox.tngwallet.com.my
TNG_CLIENT_ID=
TNG_CLIENT_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
