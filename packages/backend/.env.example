# Server
PORT=4000
NODE_ENV=development
APP_ENV=local
PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated allowed origins
# Multi-origin example (deployed): CORS_ORIGIN=https://duitlater.com,https://dev.duitlater.com
CORS_ORIGIN=http://localhost:3000

# Database
POSTGRES_USER=duitlater
POSTGRES_PASSWORD=duitlater_dev
POSTGRES_DB=duitlater
DATABASE_URL=postgresql://duitlater:duitlater_dev@localhost:5432/duitlater

# Multi-VPS free mode — app records stay in Postgres, not Syncthing
DB_ROLE=primary
DB_PRIMARY_HOST=localhost
DB_REPLICATION_USER=replicator
DB_REPLICATION_PASSWORD=
DB_PEER_ALLOWLIST=

# Local uploads — Syncthing can sync this folder between VPS peers
UPLOAD_DRIVER=local
UPLOAD_ROOT=.local/uploads
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf

# Syncthing file sync — files only, never the Postgres data directory
SYNC_DRIVER=syncthing
SYNCTHING_FOLDER_ID=duitlater-local-uploads
SYNCTHING_PEER_PUBLIC_IPS=
SYNCTHING_PORT=22000

# Auth
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:4000
# Production only: set to ".duitlater.com" so the session cookie is shared
# across dev.duitlater.com (frontend) and api.dev.duitlater.com (backend).
# Leave blank in local dev — Better Auth defaults work fine on localhost.
AUTH_COOKIE_DOMAIN=

# SMTP email verification
# Use port 587 with STARTTLS, or 465 with SMTP_SECURE=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DuitLater <no-reply@duitlater.com>"
SMTP_EHLO_DOMAIN=duitlater.com
SMTP_TIMEOUT_MS=12000

# Penasihat AI (Claude Haiku 4.5 via Amazon Bedrock OpenAI-compatible endpoint)
# Bedrock issues short-lived API keys (12h default) from the Bedrock console.
# Naming follows OPENAI_* convention because Bedrock keys are designed as
# drop-in OpenAI SDK creds — pointing the OpenAI client at the Bedrock URL.
OPENAI_BASE_URL=https://bedrock-mantle.ap-southeast-2.api.aws/v1
OPENAI_API_KEY=
AWS_REGION=ap-southeast-2

# Legacy / optional fallbacks — Penasihat heuristic is used if BEDROCK_API_KEY is empty
ALIBABA_FUNCTION_COMPUTE_URL=
ALIBABA_FUNCTION_COMPUTE_URL_NADI=
ALIBABA_FUNCTION_COMPUTE_KEY=
ANTHROPIC_API_KEY=

# AWS S3 optional later — not required for free local-upload mode
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# TNG eWallet
TNG_API_BASE=https://sandbox.tngwallet.com.my
TNG_CLIENT_ID=
TNG_CLIENT_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
