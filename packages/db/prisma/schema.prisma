generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HealthCheck {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// MyKasih product catalogue
// ---------------------------------------------------------------------------

enum MykasihCategory {
  GROCERY
  DAIRY
  PRODUCE
  HOUSEHOLD
  PERSONAL_CARE
  BABY
  BEVERAGE
  FROZEN
}

model MykasihProduct {
  id          String          @id @default(cuid())
  name        String
  nameMs      String?
  brand       String?
  category    MykasihCategory
  description String?
  unit        String
  priceRm     Decimal         @db.Decimal(10, 2)
  subsidyRm   Decimal         @db.Decimal(10, 2)
  imageUrl    String?
  barcode     String?         @unique
  stock       Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  poolTransactions PoolTransaction[]

  @@index([category])
  @@index([isActive])
}

// ---------------------------------------------------------------------------
// Better Auth — managed tables (will be auto-generated by Better Auth CLI,
// but pre-declaring them so Prisma migrations track them)
// ---------------------------------------------------------------------------

model User {
  id                       String   @id @default(cuid())
  email                    String   @unique
  emailVerified            Boolean  @default(false)
  name                     String
  image                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  // DuitLater extensions
  kampungId                String?
  individualPaylaterCents  Int      @default(30000) // RM 300 default for B40 demo
  role                     UserRole @default(MEMBER)

  kampung                  Kampung? @relation(fields: [kampungId], references: [id])
  sessions                 Session[]
  accounts                 Account[]

  initiatedPools           Pool[]            @relation("PoolInitiator")
  poolMemberships          PoolMember[]
  votes                    PoolVote[]
  obligations              PaylaterObligation[]
  repayments               Repayment[]
  uploads                  UploadAsset[]

  @@index([kampungId])
  @@index([role])
}

enum UserRole {
  MEMBER
  NADI_STAFF
  ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken      String?
  idToken           String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  password          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// NADI centres (scraped reference data from nadi.my)
// ---------------------------------------------------------------------------

model NadiCentre {
  id           String   @id // scraper id e.g. "selangor-felda-gedangsa"
  name         String
  state        String
  districtHint String?
  rawPosition  Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([state])
  @@index([districtHint])
  @@index([rawPosition])
}

// ---------------------------------------------------------------------------
// Kampung (sourced from scraped NADI centres)
// ---------------------------------------------------------------------------

model Kampung {
  id              String   @id @default(cuid())
  name            String
  state           String   @default("Selangor")
  districtHint    String?
  nadiCentreId    String   @unique // matches NADI scraper id e.g. "selangor-felda-gedangsa"
  trustScore      Decimal  @default(60) @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  pools           Pool[]

  @@index([state])
  @@index([districtHint])
}

// ---------------------------------------------------------------------------
// Pool — the core mechanic
// ---------------------------------------------------------------------------

enum PoolState {
  DRAFT
  LOCKED
  SUGGESTING
  VOTING
  APPROVED
  ACTIVE
  COMPLETED
  DISSOLVED
}

enum PoolCategory {
  EQUIPMENT
  GROCERY
  SCHOOL_SUPPLIES
  AGRICULTURAL
  APPLIANCE
  TRANSPORT
  OTHER
}

model Pool {
  id                       String       @id @default(cuid())
  kampungId                String
  initiatorUserId          String
  name                     String
  statedNeed               String
  category                 PoolCategory
  targetBudgetCents        Int
  combinedCapCents         Int          @default(0)
  inviteCode               String?      @unique
  selectedCatalogueItemId  String?
  state                    PoolState    @default(DRAFT)
  createdAt                DateTime     @default(now())
  lockedAt                 DateTime?
  approvedAt               DateTime?
  deliveredAt              DateTime?
  completedAt              DateTime?
  updatedAt                DateTime     @updatedAt

  kampung      Kampung           @relation(fields: [kampungId], references: [id])
  initiator    User              @relation("PoolInitiator", fields: [initiatorUserId], references: [id])
  members      PoolMember[]
  suggestions  PoolSuggestion[]
  votes        PoolVote[]
  transaction  PoolTransaction?

  @@index([kampungId])
  @@index([initiatorUserId])
  @@index([state])
  @@index([inviteCode])
}

model PoolMember {
  id                              String   @id @default(cuid())
  poolId                          String
  userId                          String
  individualAllowanceAtLockCents  Int      @default(0) // snapshot at lock time
  joinedAt                        DateTime @default(now())

  pool         Pool                  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id])
  obligations  PaylaterObligation[]

  @@unique([poolId, userId])
  @@index([userId])
}

model PoolSuggestion {
  id           String   @id @default(cuid())
  poolId       String
  itemsJson    Json
  provider     String   // "alibaba-qwen" | "anthropic-claude" | "heuristic"
  suggestedAt  DateTime @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId])
}

model PoolVote {
  id          String   @id @default(cuid())
  poolId      String
  userId      String
  itemId      String   // selectedCatalogueItemId at time of vote
  vote        VoteChoice
  votedAt     DateTime @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([poolId, userId, itemId])
  @@index([poolId])
}

enum VoteChoice {
  YES
  NO
}

// ---------------------------------------------------------------------------
// Transaction + Obligation + Repayment (financial ledger · append-only)
// ---------------------------------------------------------------------------

model PoolTransaction {
  id                  String   @id @default(cuid())
  poolId              String   @unique
  catalogueItemId     String
  totalAmountCents    Int
  approvedAt          DateTime @default(now())
  deliveredAt         DateTime?

  pool          Pool                  @relation(fields: [poolId], references: [id])
  catalogueItem MykasihProduct        @relation(fields: [catalogueItemId], references: [id])
  obligations   PaylaterObligation[]

  @@index([catalogueItemId])
}

model PaylaterObligation {
  id                String   @id @default(cuid())
  transactionId     String
  poolMemberId      String
  userId            String
  shareAmountCents  Int
  sharePct          Decimal  @db.Decimal(5, 2)
  totalCycles       Int      @default(6) // 6-month default repayment
  cyclesPaid        Int      @default(0)
  tngReference      String?
  createdAt         DateTime @default(now())

  transaction PoolTransaction @relation(fields: [transactionId], references: [id])
  poolMember  PoolMember      @relation(fields: [poolMemberId], references: [id])
  user        User            @relation(fields: [userId], references: [id])
  repayments  Repayment[]

  @@index([userId])
  @@index([transactionId])
}

model Repayment {
  id              String   @id @default(cuid())
  obligationId    String
  userId          String
  cycleNumber     Int
  amountCents     Int
  tngReference    String?
  paidAt          DateTime @default(now())

  obligation PaylaterObligation @relation(fields: [obligationId], references: [id])
  user       User               @relation(fields: [userId], references: [id])

  @@unique([obligationId, cycleNumber])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Upload assets — local VPS disk files replicated by Syncthing
// ---------------------------------------------------------------------------

model UploadAsset {
  id           String   @id @default(cuid())
  ownerUserId  String
  originalName String
  storedName   String
  relativePath String   @unique
  publicUrl    String
  mimeType     String
  sizeBytes    Int
  sha256       String
  visibility   String   @default("PUBLIC")
  createdAt    DateTime @default(now())

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([sha256])
  @@index([createdAt])
}
