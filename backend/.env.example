NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://duitlater:duitlater_dev@localhost:5432/duitlater

# Better Auth
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=dev-secret-replace-with-openssl-rand-base64-32

# AWS S3 (optional for MVP — for image uploads if added later)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=duitlater-uploads-dev

# Anthropic (AI Penasihat fallback · used when Alibaba FC unset/down)
ANTHROPIC_API_KEY=

# Alibaba Cloud Function Compute (multi-cloud · sponsor-aligned · primary AI)
# When set, Penasihat suggestion routes through Alibaba FC (Qwen LLM wrapper).
# Failover to Anthropic Claude if Alibaba returns 5xx or times out.
ALIBABA_FUNCTION_COMPUTE_URL=
ALIBABA_FUNCTION_COMPUTE_URL_NADI=
ALIBABA_FUNCTION_COMPUTE_KEY=

# TNG PayLater (sandbox keys obtained at organizer briefing · simulated for demo if absent)
TNG_PAYLATER_API_BASE=https://sandbox.tngwallet.com.my
TNG_CLIENT_ID=
TNG_CLIENT_SECRET=
TNG_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
