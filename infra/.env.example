# Copy to infra/.env on each VPS.
# Use with: docker compose --env-file infra/.env -f infra/docker-compose.prod.yml -p prod up -d

# Domains
DUITLATER_DOMAIN=duitlater.com
PROD_HOSTNAME=duitlater.com
DEV_HOSTNAME=dev.duitlater.com
DNS_MODE=cloudflare_round_robin_free

# VPS identity
SERVER_NAME=server-1
SERVER_PUBLIC_IP=
SERVER_PUBLIC_IPS=<server-1-ip>,<server-2-ip>,<server-3-ip>
PEER_PUBLIC_IP_ALLOWLIST=<server-1-ip>,<server-2-ip>,<server-3-ip>

# Image tags
BACKEND_TAG=latest
DEV_BACKEND_TAG=dev
FRONTEND_TAG=latest
DEV_FRONTEND_TAG=dev

# Local upload storage on the host.
# Syncthing syncs these folders between VPS peers. Do not sync Postgres data.
PROD_UPLOAD_HOST_PATH=/var/lib/duitlater/prod/uploads
DEV_UPLOAD_HOST_PATH=/var/lib/duitlater/dev/uploads

# Syncthing host-level service
SYNCTHING_CONFIG_HOST_PATH=/var/lib/duitlater/syncthing/config
SYNCTHING_UID=1000
SYNCTHING_GID=1000
SYNCTHING_PORT=22000
SYNCTHING_GUI_BIND=127.0.0.1:8384
