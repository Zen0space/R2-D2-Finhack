# DuitLater · Caddy reverse proxy
# Pattern A: same-domain path-routing per environment. No CORS.
# Two subdomains route to two compose stacks via Docker DNS on the shared `duitlater_web` network.
#
# Set DUITLATER_DOMAIN at deploy time, e.g. export DUITLATER_DOMAIN=duitlater.com
#   → prod served at         duitlater.com
#   → dev  served at     dev.duitlater.com

{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    # DB-aware readiness for DNS/proxy checks.
    handle /health {
        reverse_proxy duitlater-prod-app:4000
    }

    # Backend API: preserve /api so /api/v1/* reaches Hono unchanged.
    handle /api/* {
        reverse_proxy duitlater-prod-app:4000
    }

    # Local uploads replicated between VPS peers by Syncthing.
    handle_path /uploads/* {
        root * /srv/uploads/prod
        file_server
    }

    # Frontend: Next.js standalone server handles everything else
    handle {
        reverse_proxy duitlater-prod-frontend:3000
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    log {
        output stdout
        format json
    }
}

dev.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    handle /health {
        reverse_proxy duitlater-dev-app:4000
    }

    handle /api/* {
        reverse_proxy duitlater-dev-app:4000
    }

    handle_path /uploads/* {
        root * /srv/uploads/dev
        file_server
    }

    handle {
        reverse_proxy duitlater-dev-frontend:3000
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
        X-Robots-Tag "noindex, nofollow"
    }

    log {
        output stdout
        format json
    }
}
