# DuitLater · standalone dev Caddyfile
# Optional fallback when running only the dev stack on a separate VPS.
#
# Set at deploy time: export DUITLATER_DOMAIN=duitlater.com

dev.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    handle /health {
        reverse_proxy duitlater-dev-app:4000
    }

    handle /api/* {
        reverse_proxy duitlater-dev-app:4000
    }

    handle_path /uploads/* {
        root * /srv/uploads/dev
        file_server
    }

    handle {
        reverse_proxy duitlater-dev-frontend:3000
    }

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        X-Robots-Tag "noindex, nofollow"
    }

    log {
        output stdout
        format json
    }
}
