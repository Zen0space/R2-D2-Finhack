# DuitLater · shared Caddyfile (dev + prod on one server)
# Subdomains:
#   <domain>         → prod Next.js frontend :3000
#   api.<domain>     → prod Hono backend :4000
#   dev.<domain>     → dev Next.js frontend :3000
#   api.dev.<domain> → dev Hono backend :4000
#
# Set at deploy time: export DUITLATER_DOMAIN=duitlater.com

(security_headers) {
    header {
        # Force HTTPS for 1y across all subdomains
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Block clickjacking
        X-Frame-Options "DENY"
        # Block MIME sniffing
        X-Content-Type-Options "nosniff"
        # Limit what referrer info leaks across origins
        Referrer-Policy "strict-origin-when-cross-origin"
        # Disable browser features we don't use
        Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        # Hide upstream server fingerprint
        -Server
    }
}

{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    reverse_proxy duitlater-prod-frontend:3000

    import security_headers

    log {
        output stdout
        format json
    }
}

dev.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    reverse_proxy duitlater-dev-frontend:3000

    import security_headers
    header X-Robots-Tag "noindex, nofollow"

    log {
        output stdout
        format json
    }
}

api.dev.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    reverse_proxy duitlater-dev-app:4000

    import security_headers
    header X-Robots-Tag "noindex, nofollow"

    log {
        output stdout
        format json
    }
}

api.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    reverse_proxy duitlater-prod-app:4000

    import security_headers

    log {
        output stdout
        format json
    }
}
