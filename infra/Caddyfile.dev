# DuitLater · dev Caddyfile
# Two subdomains:
#   dev.<domain>     → Next.js frontend :3000
#   api.dev.<domain> → Hono backend :4000  (no /api/ stripping — backend owns full path)
#
# Set at deploy time: export DUITLATER_DOMAIN=duitlater.com

dev.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    reverse_proxy duitlater-dev-frontend:3000

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        X-Robots-Tag "noindex, nofollow"
    }

    log {
        output stdout
        format json
    }
}

api.dev.{$DUITLATER_DOMAIN:localhost} {
    encode gzip zstd

    reverse_proxy duitlater-dev-app:4000

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        X-Robots-Tag "noindex, nofollow"
    }

    log {
        output stdout
        format json
    }
}
