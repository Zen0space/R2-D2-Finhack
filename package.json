{
  "name": "r2-d2-finhack",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "predev": "pnpm db:generate && bash scripts/kill-ports.sh",
    "dev": "pnpm --parallel --filter './packages/{backend,frontend}' dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "db:up": "docker compose -f infra/docker-compose.local.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.local.yml down",
    "db:logs": "docker compose -f infra/docker-compose.local.yml logs -f postgres",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:migrate:new": "pnpm --filter db migrate:new",
    "db:studio": "pnpm --filter db studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
